# =============================================================
# MassGrowth SaaS — переменные окружения
# Скопируйте в .env и заполните перед запуском
# .env НЕ коммитить в git!
# =============================================================

# Приложение
APP_ENV=development            # development | production
SECRET_KEY=change-me-32chars   # Минимум 32 символа, случайная строка
CONFIG_PATH=config.yaml

# База данных
DATABASE_URL=sqlite:///./data/massgrowth.db
# Для PostgreSQL (продакшн):
# DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/massgrowth

# API
API_HOST=0.0.0.0
API_PORT=8000

# CORS: разрешённые origins через запятую
# В продакшне укажи реальный домен фронтенда: https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Прокси (через запятую, формат: http://user:pass@host:port)
# 1 прокси на 1 аккаунт — строго!
PROXY_LIST=

# Instagram credentials (для первичного логина)
# Хранятся зашифрованными в БД после первого входа
# IG_USERNAME и IG_PASSWORD используются ТОЛЬКО при первом логине
# Далее работа идёт через сессию (cookies)
IG_USERNAME=
IG_PASSWORD=

# Логирование
LOG_LEVEL=INFO
LOG_DIR=logs

# Уведомления (Telegram) — TODO
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
